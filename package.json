{
  "name": "codex-web-ui",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "codex-web-ui": "./bin/codex-web-ui.mjs"
  },
  "files": [
    "bin",
    "dist",
    "scripts/start.ts",
    "server",
    "README.md",
    "tsconfig.server.json"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "tsx watch server/index.ts --mock",
    "start": "tsx scripts/start.ts",
    "install:global": "npm link --ignore-scripts",
    "prepublishOnly": "npm run build && npm test",
    "build": "vite build && tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "probe:continuity": "tsx scripts/probe-continuity.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cookie": "^0.7.2",
    "express": "^4.21.2",
    "tsx": "^4.19.4",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@playwright/test": "^1.52.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "jsdom": "^24.1.3",
    "katex": "^0.16.22",
    "lucide-react": "^0.475.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "typescript": "^5.8.3",
    "vite": "^5.4.18",
    "vitest": "^2.1.9"
  }
}
